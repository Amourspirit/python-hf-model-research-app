# hf-model-exporter environment example
# Copy to .env and edit values as needed.
# Values here are examples; docker-compose defaults still apply when unset.

# -----------------------------------------------------------------------------
# Project-specific variables used by docker-compose services
# -----------------------------------------------------------------------------

# Hugging Face User Access Token.
# If set, this overrides token file auth and enables higher Hub rate limits.
HF_TOKEN=

# SQLite DB path for exporter services.
HF_EXPORTER_DB_PATH=/storage/hf_exporter.db

# Storage root consumed by web service.
HF_EXPORTER_STORAGE_DIR=/storage

# Custom hf-shell wrapper defaults for download/cache paths.
HF_SHELL_DOWNLOAD_DIR=/storage/hf-shell/downloads
HF_SHELL_CACHE_DIR=/storage/hf-shell/cache

# -----------------------------------------------------------------------------
# Hugging Face Hub generic environment variables
# Docs: https://huggingface.co/docs/huggingface_hub/package_reference/environment_variables
# -----------------------------------------------------------------------------

# Base HF home used to store token/cache data.
# Default: ~/.cache/huggingface (or $XDG_CACHE_HOME/huggingface when HF_HOME is unset)
HF_HOME=/storage/hf-shell

# Repository cache directory (models/datasets/spaces).
# Default: $HF_HOME/hub
HF_HUB_CACHE=/storage/hf-shell/cache

# Asset cache directory for downstream libraries.
# Default: $HF_HOME/assets
HF_ASSETS_CACHE=/storage/hf-shell/assets

# Active token file path.
# Default: $HF_HOME/token
HF_TOKEN_PATH=/storage/hf-shell/token

# Custom Inference API endpoint.
# Default: https://api-inference.huggingface.co
HF_INFERENCE_ENDPOINT=

# Logger verbosity: debug|info|warning|error|critical
# Default: warning
HF_HUB_VERBOSITY=warning

# Timeout (seconds) for metadata (etag) requests.
# Default: 10
HF_HUB_ETAG_TIMEOUT=10

# Timeout (seconds) for file download requests.
# Default: 10
HF_HUB_DOWNLOAD_TIMEOUT=10

# -----------------------------------------------------------------------------
# Hugging Face Hub boolean toggles (True when one of: 1, ON, YES, TRUE)
# Any other value (or unset) is False.
# -----------------------------------------------------------------------------

# Enable debug logging + curl-equivalent request logs.
HF_DEBUG=

# Disable network calls and use local cache only.
HF_HUB_OFFLINE=False

# Do not send auth token implicitly on read requests.
HF_HUB_DISABLE_IMPLICIT_TOKEN=False

# Disable tqdm progress bars globally.
HF_HUB_DISABLE_PROGRESS_BARS=

# Disable symlink usage in cache (may increase disk usage).
HF_HUB_DISABLE_SYMLINKS=

# Disable symlink warning messages (mostly relevant on Windows).
HF_HUB_DISABLE_SYMLINKS_WARNING=False

# Disable warnings for experimental features.
HF_HUB_DISABLE_EXPERIMENTAL_WARNING=False

# Disable telemetry across Hugging Face Python ecosystem.
HF_HUB_DISABLE_TELEMETRY=True

# Disable hf-xet usage even if installed.
HF_HUB_DISABLE_XET=False

# -----------------------------------------------------------------------------
# Xet-specific environment variables
# -----------------------------------------------------------------------------

# Xet cache directory.
# Default: $HF_HOME/xet
HF_XET_CACHE=

# Increase network/CPU usage for higher transfer throughput.
HF_XET_HIGH_PERFORMANCE=

# Prefer sequential writes for slower HDDs.
HF_XET_RECONSTRUCT_WRITE_SEQUENTIALLY=

# Chunk cache size (bytes). Default: 0 (disabled)
HF_XET_CHUNK_CACHE_SIZE_BYTES=

# Shard cache soft limit (bytes). Default: 4000000000
HF_XET_SHARD_CACHE_SIZE_LIMIT=

# Concurrent range GET requests. Default: 16
HF_XET_NUM_CONCURRENT_RANGE_GETS=

# -----------------------------------------------------------------------------
# External-tool env vars recognized by huggingface_hub
# -----------------------------------------------------------------------------

# Equivalent to HF_HUB_DISABLE_TELEMETRY when truthy.
DO_NOT_TRACK=

# Disable ANSI color output in hf CLI.
NO_COLOR=

# Used only when HF_HOME is unset.
XDG_CACHE_HOME=
